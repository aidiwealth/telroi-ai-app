# ─── Core ───────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/telroi
APP_BASE_URL=http://localhost:3000
ROOT_DOMAIN=telroi.ai
NODE_ENV=development

# ─── Security (generate strong values) ──────────────────
# JWT signing secret (any long random string)
JWT_SECRET=replace-with-long-random-string
# AES-256 key — MUST be 32 bytes, base64-encoded:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace-with-32-byte-base64-key

# ─── Email (passwordless login) ─────────────────────────
# 'console' logs the link/code to stdout (dev). 'resend' sends real email.
# 'termii' sends sign-in/verification CODES via Termii's email-OTP API.
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=Telroi <hello@telroi.ai>
# Termii email-OTP (used when EMAIL_PROVIDER=termii). Get these from your
# Termii dashboard. BASE_URL is account-specific (e.g. https://api.ng.termii.com).
# Note: Termii only delivers the OTP code; magic links / invites / policy emails
# fall back to Resend if configured, otherwise the console. Set RESEND_API_KEY
# too if you want those non-OTP emails delivered for real.
TERMII_API_KEY=
TERMII_EMAIL_CONFIG_ID=
TERMII_BASE_URL=https://api.ng.termii.com

# ─── Telroi PBX (optional offline mock) ─────────────────
# Point at the bundled mock to run without live Digitide creds:
#   TELROI_MOCK_URL=http://localhost:3000/_mock/crmapi/v1
TELROI_MOCK_URL=

# ─── Wallet / payments ──────────────────────────────────
# Paystack (NGN top-ups). Get keys at dashboard.paystack.com
PAYSTACK_SECRET_KEY=
# Stripe (USD top-ups). Get keys at dashboard.stripe.com
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (whsec_...) from your webhook endpoint config
STRIPE_WEBHOOK_SECRET=

# ─── Monnify (Nigerian bank-transfer top-ups) ──────────
# From your Monnify dashboard (Developers section)
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_ENV=sandbox

# ─── Cloudflare R2 (document storage) ───────────────────
# S3-compatible object storage for KYC docs and uploads.
# From your Cloudflare dashboard → R2 → Manage R2 API Tokens.
# Leave blank to fall back to local disk storage (dev only).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=telroi-docs
# Optional: where local-fallback files go (when R2 is not configured)
LOCAL_STORAGE_DIR=/tmp/telroi-storage

# ─── Login bot-gate (optional CAPTCHA) ──────────────────
# Stops automated abuse of the login SEND endpoint (each send costs money).
# Leave unset to disable — strong rate limiting still applies either way.
# Recommended: Cloudflare Turnstile (free). Or Google reCAPTCHA.
CAPTCHA_PROVIDER=          # turnstile | recaptcha | (empty = off)
CAPTCHA_SECRET=            # secret key from the provider
NUXT_PUBLIC_CAPTCHA_SITE_KEY=   # public site key for the widget

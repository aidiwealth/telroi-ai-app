# control-app/.env.example
# Copy this to .env on the Asterisk Droplet and fill in real values.
# This file (.env.example) is safe to commit; the real .env is NOT (gitignored).

# --- ARI (local Asterisk on this same Droplet) ---
# The control app runs ON the Asterisk box, so it talks to ARI over localhost
# plain HTTP 8088 (internal, never leaves the machine). Do NOT use the public
# TLS 8089 here — that is for Telroi reaching in from outside.
ARI_URL=http://127.0.0.1:8088
ARI_USERNAME=telroi
ARI_PASSWORD=replace-with-your-ari-password
ARI_APP_NAME=telroi

# --- Database (the same Postgres Telroi uses) ---
# Needed from Stage 2 onward (DID->client resolution, blacklist, routing).
# The Droplet's IP must be in the DB's Trusted Sources for this to connect.
DATABASE_URL=postgresql://doadmin:PASSWORD@telroi-db-pgsql-01357-do-user-23838674-0.a.db.ondigitalocean.com:25060/defaultdb?sslmode=require

LOG_LEVEL=info

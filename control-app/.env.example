# control-app/.env.example
# Copy to .env on the host and fill in real values. Real .env is gitignored.

# --- ARI connection ---
# ARI_URL = PROTOCOL + HOST only (no /ari path — the client adds it).
#
# If the control app runs ON the Asterisk box (London):
#   ARI_URL=http://127.0.0.1:8088
# If the control app runs on a DIFFERENT box (e.g. this NYC droplet -> London PBX):
#   ARI_URL=https://sip.telroi.ai:8089
ARI_URL=https://sip.telroi.ai:8089
ARI_USERNAME=telroi
ARI_PASSWORD=replace-with-your-ari-password
ARI_APP_NAME=telroi

# --- Database (same Postgres the main app uses) ---
# On the NYC box this is local/fast. The cache layer still runs (harmless,
# and gives resilience to brief DB blips).
DATABASE_URL=postgresql://doadmin:PASSWORD@telroi-db-pgsql-01357-do-user-23838674-0.a.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# How often (ms) to refresh the routing cache from the DB. Default 30000.
CACHE_REFRESH_MS=30000

LOG_LEVEL=info
